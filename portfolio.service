[Unit]
Description=Sai Portfolio Flask App
After=network.target mysql.service

[Service]
User=root
Group=root
WorkingDirectory=/root/saiborg-personal-website
EnvironmentFile=/root/saiborg-personal-website/.env
Environment=FLASK_APP=app
ExecStart=/root/saiborg-personal-website/python3-virtualenv/bin/gunicorn --workers 2 --bind 0.0.0.0:5000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
